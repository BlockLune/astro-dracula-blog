{
  "name": "astro-blog",
  "type": "module",
  "version": "0.0.1",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "new": "node scripts/new.js",
    "format:check": "oxfmt --check src public scripts astro.config.mjs package.json README.md tailwind.config.mjs tsconfig.json",
    "format": "oxfmt src public scripts astro.config.mjs package.json README.md tailwind.config.mjs tsconfig.json",
    "lint": "oxlint .",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/fira-code": "^5.2.7",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "astro": "^7.0.6",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.2",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-string": "^4.0.0",
    "minimist": "^1.2.8",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-external-links": "^3.0.0",
    "rehype-github-alerts": "4.2.0",
    "rehype-mathjax": "^7.1.0",
    "remark-math": "^6.0.0",
    "satori": "^0.26.0",
    "slugify": "^1.6.9",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "use-debounce": "^10.1.1"
  },
  "devDependencies": {
    "lint-staged": "^15.5.2",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "simple-git-hooks": "^2.13.1"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx}": [
      "oxfmt",
      "oxlint --fix"
    ],
    "*.astro": "oxlint --fix",
    "*.{json,jsonc,css,md,yml,yaml,html}": "oxfmt"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  }
}
