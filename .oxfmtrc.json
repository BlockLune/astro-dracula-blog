{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "tabWidth": 2,
  "printWidth": 80,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "sortTailwindcss": {
    "stylesheet": "./src/styles/global.css"
  },
  "sortPackageJson": false,
  "ignorePatterns": ["dist/**", ".astro/**", "node_modules/**"]
}
